{
  "name": "sircode",
  "version": "0.1.0",
  "description": "Ollama-powered CLI coding assistant inspired by Claude Code",
  "type": "module",
  "bin": {
    "sircode": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc",
    "start": "node dist/cli.js",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "ollama",
    "cli",
    "coding",
    "assistant",
    "ai",
    "llm"
  ],
  "author": "Sirco-web",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
